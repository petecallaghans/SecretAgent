{
  "name": "secret-agent",
  "version": "1.0.0",
  "description": "Lightweight AI agent with Telegram interface",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "predev": "test -f .env || tsx src/setup.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "prestart": "test -f .env || tsx src/setup.ts",
    "start": "node dist/index.js",
    "setup": "tsx src/setup.ts",
    "service": "tsx src/service.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.70",
    "dotenv": "^16.4.7",
    "grammy": "^1.31.0",
    "node-cron": "^3.0.3",
    "openai": "^6.27.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
